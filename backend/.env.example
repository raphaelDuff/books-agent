# PostgreSQL connection URL
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/samizdat

# Repository backend type (currently only 'postgresql' is supported)
CONFIG_REPOSITORY_TYPE=postgresql

# Set to 'true' to enable SQLAlchemy query logging (useful for debugging)
DATABASE_ECHO=false

# Auth
SECRET_KEY=121fee1f51c2c5abfdef1d5a2a3b6a292791d57d83a7f83a1437f76ec2c00379
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# --- Recommendation agent ---
# OpenAI (chat model for classify/repair/rank + embeddings for semantic search)
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Weaviate (run via docker-compose at the repo root)
WEAVIATE_URL=http://localhost:8080
WEAVIATE_COLLECTION=Book

# Text-to-SQL guard tuning
SQL_MAX_LIMIT=50
SQL_STATEMENT_TIMEOUT_MS=5000

# Data-prep script only: path to the Kaggle dataset CSV (default: repo root)
BOOKS_CSV_PATH=../books.csv

# Optional LangSmith tracing
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...